    <!-- App description strings (used in main/about screens) -->
    <string name="app_description">
        This application scans QR codes and analyzes URLs for phishing, malicious redirects,
        and unsafe patterns using heuristic rules and threat intelligence APIs.
    </string>


    <string name="what_it_detects">
        What we use:\n
        • Google Safe Browsing checks\n
        • PhishTank verification\n
        • URL Resolution\n
        • Heuristics Analysis of URL\n
        • TLS Certification Validation\n
    </string>
    <string name="final_risk_scoring">
        Final Risk Scoring:\n
        • Dangerous >= 5\n
        • Suspicious >= 2\n
        • else Safe\n
    </string>

    <string name="api_scoring">
        API Check Scoring:\n
        • Google Safe Browsing Hit = 5\n
        • PhishTank Hit = 5\n
    </string>

    <string name="cert_scoring">
        TLS Validation Scoring:\n
        • TLS Handshake Fail = 3\n
        • Cert Expired = 2\n
        • Cert Domain Mismatch = 2\n
        • Self-Signed Cert = 1\n
        • Cert Not Yet Valid = 1\n
    </string>

    <string name="heuristics_scoring">
        Heuristics Scoring:\n
        • More Than 5 Redirects = 2\n
        • URl is shortened = 1\n
        • URL uses IP Address = 2\n
        • URL uses HTTP instead of HTTPS = 1\n
        • URl uses ftp, file or javascript = 1\n
        • URl uses keyword = 1\n
    </string>

